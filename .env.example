# --- GitHub -----------------------------------------------------------------
# Fine-grained PAT with read access to: Issues, Pull requests, Contents, Projects.
# A write-scoped token (Issues: write) is only needed if you post enrichment
# comments back with `secretary enrich --write`.
SECRETARY_GITHUB_TOKEN=github_pat_xxx

# The repo(s) to index. Use GITHUB_REPOS (comma-separated) for several repos in
# one shared database, or GITHUB_REPO for a single one.
SECRETARY_GITHUB_REPOS=owner/repo,owner/another-repo
# SECRETARY_GITHUB_REPO=owner/repo

# Repos allowed to surface as related to each other on weaker (non-edge) signals.
# Comma-separated pairs joined by '+'. Leave empty to require an explicit edge.
# SECRETARY_RELATED_REPO_PAIRS=owner/api+owner/worker

# --- SurrealDB --------------------------------------------------------------
SECRETARY_SURREAL_URL=ws://127.0.0.1:8000/rpc
SECRETARY_SURREAL_USER=root
SECRETARY_SURREAL_PASS=root
SECRETARY_SURREAL_NS=secretary
SECRETARY_SURREAL_DB=secretary

# --- Polling ----------------------------------------------------------------
SECRETARY_POLL_INTERVAL_SECONDS=300
